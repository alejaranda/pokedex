---
export interface Props {
  id: number;
  name: string;
  types: string[];
  hp: number;
}

const { id, name, types = [], hp } = Astro.props;

const num = String(id).padStart(3, "0");

const sprite = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${id}.png`;

const primaryType = types[0]?.toLowerCase() ?? "normal";
---

<article
  class="flex overflow-hidden rounded-lg border border-zinc-200 bg-white transition hover:-translate-y-0.5 hover:border-zinc-300 sm:flex-col"
  style={`--pk-color: var(--type-${primaryType});`}
>
  <div class="w-1 shrink-0 bg-(--pk-color) sm:h-1 sm:w-auto"></div>

  <div
    class="flex shrink-0 items-center justify-center bg-zinc-100 px-3 py-2 sm:px-0 sm:py-3"
  >
    <img
      src={sprite}
      alt={name}
      loading="lazy"
      class="pixelated h-14 w-14 sm:h-16 sm:w-16"
    />
  </div>

  <div class="flex flex-1 flex-col justify-center p-2.5">
    <div class="mb-1 flex items-baseline justify-between">
      <span class="font-pokemon text-[7px] text-zinc-400">#{num}</span>
      <span class="font-pokemon text-[6px] text-zinc-500">
        <b class="text-[9px] text-(--pk-color)">{hp}</b> HP
      </span>
    </div>
    <p
      class="mb-1.5 font-pokemon text-[7px] capitalize leading-[1.4] text-(--pk-ink)"
    >
      {name}
    </p>
    <div class="flex flex-wrap gap-1">
      {
        types.map((type) => (
          <span
            class="rounded px-1.5 py-0.5 font-pokemon text-[7px] font-semibold capitalize text-white"
            style={`background: var(--type-${type.toLowerCase()})`}
          >
            {type}
          </span>
        ))
      }
    </div>
  </div>
</article>
