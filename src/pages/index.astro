---
import PokemonCard from "../components/Card.astro";
import { getPokemonList } from "../lib/pokemon";
import "../global.css";

const pokemon = await getPokemonList();
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Pokédex</title>
	</head>
	<body>
		<main class="mx-auto max-w-6xl px-4 py-6 sm:px-5 sm:py-8">
			<div
				class="flex flex-col gap-2 sm:grid sm:grid-cols-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
			>
				{
					pokemon.map((p) => (
						<PokemonCard id={p.id} name={p.name} types={p.types} hp={p.hp} />
					))
				}
			</div>
		</main>
	</body>
</html>
